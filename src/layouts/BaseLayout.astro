---
import BaseHead from "../components/Scaffolding/BaseHead.astro";
import Footer from "../components/Scaffolding/Footer.astro";
import SiteTitle from "../components/Scaffolding/SiteTitle.astro";
import Tracking from "../components/Scaffolding/Tracking.astro";
import PagefindSearch from "../components/Search/PagefindSearch.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../constants";

interface Props {
    searchable?: boolean;
}

const { searchable = true } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <Tracking />
    </head>
    <body>
        <main class="container">
            <div class="header-container" data-pagefind-ignore="all">
                <div>
                    <SiteTitle variant="home" />
                </div>
                <div>
                    <PagefindSearch />
                </div>
            </div>
            <p class="site-tagline" data-pagefind-ignore>{SITE_DESCRIPTION}</p>
            <div data-pagefind-body={searchable ? "" : undefined}>
                <slot />
            </div>
            <Footer />
        </main>
    </body>
</html>

<style>
    .site-tagline {
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
    }
</style>
